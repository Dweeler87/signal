# ClickHouse Cloud connection
CLICKHOUSE_HOST=your-instance.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=signal

# Redis (local: redis://localhost:6379, prod: redis://your-vm-ip:6379)
REDIS_URL=redis://localhost:6379

# People Data Labs — Phase 2+
# Sign up at https://www.peopledatalabs.com/
PDL_API_KEY=

# FastAPI signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=

# Logging
LOG_LEVEL=info
